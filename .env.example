BOT_TOKEN=your_telegram_bot_token

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Оставь пустым — бот сам подберёт актуальную бесплатную модель через API
# Или укажи конкретную (ID модели с openrouter.ai/models?q=free)
OPENROUTER_MODEL=

# Tavily Search API (https://tavily.com)
TAVILY_API_KEY=tvly-...

APP_URL=http://localhost:8080
WEBHOOK_PORT=8080
PAID_PLAN_DAYS=30
