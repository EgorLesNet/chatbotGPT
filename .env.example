BOT_TOKEN=your_telegram_bot_token

# Groq API (самый быстрый облак, https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
# Оставь пустым — используются llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
GROQ_MODEL=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
# Оставь пустым — бот сам подберёт актуальную бесплатную модель
OPENROUTER_MODEL=

# Локальный llama.cpp сервер (опционально)
# Запуск: ~/llama.cpp/build/bin/llama-server --model ~/models/Qwen2.5-7B-Instruct/Qwen2.5-7B-Instruct-Q4_K_M.gguf --port 11434 -ngl 0
LLAMACPP_URL=http://localhost:11434
LLAMACPP_MODEL=Qwen2.5-7B-Instruct-Q4_K_M

# Tavily Search API (https://tavily.com)
TAVILY_API_KEY=tvly-...

APP_URL=http://localhost:8080
WEBHOOK_PORT=8080
PAID_PLAN_DAYS=30
