BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Username Tribute-канала для проверки подписки (например @mychannel)
# Оставь пустым, если не используешь Tribute
TRIBUTE_CHANNEL=
# Путь к файлу хранилища (по умолчанию users.json рядом с main.py)
DATA_FILE=users.json
