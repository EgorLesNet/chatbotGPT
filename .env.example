BOT_TOKEN=your_telegram_bot_token

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
# Бесплатные модели: mistralai/mistral-7b-instruct:free | google/gemma-3-12b-it:free
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Tavily Search API (https://tavily.com) - бесплатно 1000 запросов/мес
# Если не задан - бот работает без поиска
TAVILY_API_KEY=tvly-...

APP_URL=http://localhost:8080
WEBHOOK_PORT=8080
PAID_PLAN_DAYS=30
