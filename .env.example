BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# API-ключ из Tribute Dashboard -> Настройки -> API-ключи
TRIBUTE_API_KEY=your_tribute_api_key_here

# Сколько дней даётся после покупки (по умолчанию 30)
SUBSCRIPTION_DAYS=30

# Бесплатный лимит в день
DAILY_FREE_LIMIT=20

# Порт для вебхука Tribute (укажи в Tribute Dashboard как https://твой_домен/tribute)
WEBHOOK_PORT=8080

# Путь к файлу хранилища
DATA_FILE=users.json
